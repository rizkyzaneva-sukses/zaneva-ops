# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://elyasr_user:GANTI_PASSWORD@localhost:5432/elyasr_ops"

# ─────────────────────────────────────────────
# SESSION SECRET (iron-session)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────
SESSION_SECRET="GANTI_DENGAN_RANDOM_STRING_32_KARAKTER_MINIMAL"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="ELYASR Business Operation"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─────────────────────────────────────────────
# AI INSIGHTS (SumoPod - OpenAI compatible)
# Endpoint: https://ai.sumopod.com/v1/chat/completions
# ─────────────────────────────────────────────
SUMOPOD_API_KEY="GANTI_DENGAN_SUMOPOD_API_KEY"

# ─────────────────────────────────────────────
# REPORT API KEY (untuk n8n → Telegram)
# Generate string acak: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# ─────────────────────────────────────────────
REPORT_API_KEY="GANTI_DENGAN_RANDOM_SECRET_KEY"

# ─────────────────────────────────────────────
# CRON SECRET (untuk internal auto-report scheduler)
# Digunakan oleh scheduler internal untuk trigger /api/report/cron-telegram
# ─────────────────────────────────────────────
CRON_SECRET="elyasr-internal-cron"

# ─────────────────────────────────────────────
# TELEGRAM BOT (untuk webhook AI assistant)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="GANTI_DENGAN_BOT_TOKEN_DARI_BOTFATHER"
TELEGRAM_OWNER_CHAT_ID="565228988"
# Bisa multi ID (comma-separated): "565228988,-100123456789"
# Termasuk group chat ID jika bot dipakai di group

# ─────────────────────────────────────────────
# ADYE AI (OpenAI-compatible API untuk Telegram AI Assistant)
# ─────────────────────────────────────────────
ADYE_API_KEY="GANTI_DENGAN_ADYE_API_KEY"
ADYE_BASE_URL="https://adye.dev/v1"
ADYE_MODEL="claude-sonnet-4-6"
