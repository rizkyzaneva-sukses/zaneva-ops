// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  OWNER
  FINANCE
  STAFF
  EXTERNAL
}

enum LedgerDirection {
  IN
  OUT
}

enum LedgerReason {
  SALES
  RETURN_PURCHASE
  PRIVE
  MARKETING
  PURCHASE
  RETURN_SALES
  ADJUSTMENT
}

enum ScanBatchStatus {
  DRAFT
  COMMITTED
  CANCELED
}

enum ScanBatchReason {
  SALES
  RETURN_PURCHASE
  PRIVE
  MARKETING
  PURCHASE
  RETURN_SALES
}

enum OpnameBatchStatus {
  DRAFT
  COMMITTED
  CANCELED
}

enum POStatus {
  OPEN
  PARTIAL
  COMPLETED
  CANCELLED
}

enum POPaymentStatus {
  UNPAID
  PARTIAL_PAID
  PAID
}

enum POItemStatus {
  OPEN
  PARTIAL
  COMPLETED
}

enum WalletTrxType {
  PAYOUT
  OTHER_INCOME
  EXPENSE
  TRANSFER
  MODAL_MASUK
  PRIVE
  INVESTASI
}

enum MasterCategoryType {
  OTHER_INCOME
  EXPENSE_BEBAN
  EXPENSE_NON_BEBAN
}

enum VendorPaymentType {
  DP
  PELUNASAN
  PARTIAL
}

enum VendorPaymentStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum UtangType {
  SUNTIKAN_MODAL
  PINJAMAN_BANK
  PINJAMAN_PRIBADI
  LAINNYA
}

enum UtangStatus {
  OUTSTANDING
  PARTIAL
  PAID
}

enum PiutangType {
  PINJAMAN_KARYAWAN
  PO_VENDOR_BELUM_DIKIRIM
  LAINNYA
}

enum PiutangStatus {
  OUTSTANDING
  PARTIAL
  COLLECTED
}

enum RelatedEntityType {
  PurchaseOrder
  VendorPayment
  Other
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SCAN
  COMMIT
  CANCEL
}

// ─────────────────────────────────────────────
// 1. AppUser
// ─────────────────────────────────────────────
model AppUser {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  username      String    @unique
  passwordHash  String    @map("password_hash")
  userRole      UserRole  @map("user_role")
  isActive      Boolean   @default(true) @map("is_active")
  fullName      String?   @map("full_name")

  @@map("app_users")
}

// ─────────────────────────────────────────────
// 2. ProductCategory
// ─────────────────────────────────────────────
model ProductCategory {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  categoryName  String    @map("category_name")
  description   String?
  isActive      Boolean   @default(true) @map("is_active")

  products      MasterProduct[]

  @@map("product_categories")
}

// ─────────────────────────────────────────────
// 3. MasterProduct
// ─────────────────────────────────────────────
model MasterProduct {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdBy       String?   @map("created_by")

  sku             String    @unique
  productName     String    @map("product_name")
  categoryId      String?   @map("category_id")
  categoryName    String?   @map("category_name")
  unit            String    @default("pcs")
  hpp             Int       @default(0)
  rop             Int       @default(0)     @map("rop")
  leadTimeDays    Int       @default(0)     @map("lead_time_days")
  stokAwal        Int       @default(0)     @map("stok_awal")
  lastOpnameDate  DateTime? @map("last_opname_date")
  variantInfo     Json?     @map("variant_info")
  isActive        Boolean   @default(true)  @map("is_active")

  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  ledgerEntries   InventoryLedger[]
  poItems         PurchaseOrderItem[]
  opnameItems     StockOpnameItem[]

  @@map("master_products")
}

// ─────────────────────────────────────────────
// 4. InventoryLedger
// ─────────────────────────────────────────────
model InventoryLedger {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  createdBy   String?         @map("created_by")

  sku         String
  trxDate     DateTime        @map("trx_date")
  direction   LedgerDirection
  reason      LedgerReason
  qty         Int
  batchId     String?         @map("batch_id")
  refOpnameId String?         @map("ref_opname_id")
  note        String?

  product     MasterProduct       @relation(fields: [sku], references: [sku])
  batch       InventoryScanBatch? @relation(fields: [batchId], references: [id])
  opname      StockOpnameBatch?   @relation(fields: [refOpnameId], references: [id])

  @@index([sku])
  @@index([trxDate])
  @@index([batchId])
  @@map("inventory_ledger")
}

// ─────────────────────────────────────────────
// 5. InventoryScanBatch
// ─────────────────────────────────────────────
model InventoryScanBatch {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  createdBy   String?         @map("created_by")

  batchDate   DateTime        @map("batch_date")
  direction   LedgerDirection
  reason      ScanBatchReason?
  status      ScanBatchStatus @default(DRAFT)
  itemsJson   Json?           @map("items_json")
  scannedBy   String?         @map("scanned_by")

  ledgerEntries InventoryLedger[]

  @@map("inventory_scan_batches")
}

// ─────────────────────────────────────────────
// 6. StockOpnameBatch
// ─────────────────────────────────────────────
model StockOpnameBatch {
  id                    String            @id @default(cuid())
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  createdBy             String?           @map("created_by")

  opnameDate            DateTime          @map("opname_date")
  warehouseName         String?           @map("warehouse_name")
  status                OpnameBatchStatus @default(DRAFT)
  note                  String?
  totalSku              Int               @default(0) @map("total_sku")
  totalAdjustmentQty    Int               @default(0) @map("total_adjustment_qty")
  committedAt           DateTime?         @map("committed_at")
  committedBy           String?           @map("committed_by")

  items                 StockOpnameItem[]
  ledgerEntries         InventoryLedger[]

  @@map("stock_opname_batches")
}

// ─────────────────────────────────────────────
// 7. StockOpnameItem
// ─────────────────────────────────────────────
model StockOpnameItem {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  opnameId    String    @map("opname_id")
  sku         String
  systemQty   Int       @map("system_qty")
  actualQty   Int       @map("actual_qty")
  diffQty     Int       @map("diff_qty")
  note        String?

  opname      StockOpnameBatch  @relation(fields: [opnameId], references: [id])
  product     MasterProduct     @relation(fields: [sku], references: [sku])

  @@index([opnameId])
  @@map("stock_opname_items")
}

// ─────────────────────────────────────────────
// 8. Order
// ─────────────────────────────────────────────
model Order {
  id                  String    @id @default(cuid())
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdBy           String?   @map("created_by")

  orderNo             String    @map("order_no")
  status              String
  platform            String?
  airwaybill          String?
  orderCreatedAt      String?   @map("order_created_at")
  trxDate             DateTime? @map("trx_date")
  sku                 String?
  productName         String?   @map("product_name")
  qty                 Int       @default(1)
  totalProductPrice   Int       @default(0) @map("total_product_price")
  realOmzet           Int       @default(0) @map("real_omzet")
  city                String?
  province            String?
  buyerUsername       String?   @map("buyer_username")
  receiverName        String?   @map("receiver_name")
  phone               String?
  hpp                 Int       @default(0)

  payout              Payout?
  scanLogs            OrderScanLog[]

  @@index([orderNo])
  @@index([airwaybill])
  @@index([status])
  @@index([platform])
  @@index([orderCreatedAt])
  @@index([trxDate])
  @@index([platform, status])
  @@index([status, orderCreatedAt])
  @@index([platform, orderCreatedAt])
  @@index([trxDate, platform])
  @@map("orders")
}

// ─────────────────────────────────────────────
// 9. OrderScanLog
// ─────────────────────────────────────────────
model OrderScanLog {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now()) @map("created_at")

  orderId     String    @map("order_id")
  orderNo     String    @map("order_no")
  scannedAt   DateTime  @map("scanned_at")
  scannedBy   String?   @map("scanned_by")
  note        String?

  order       Order     @relation(fields: [orderId], references: [id])

  @@index([orderNo])
  @@map("order_scan_logs")
}

// ─────────────────────────────────────────────
// 10. Wallet
// ─────────────────────────────────────────────
model Wallet {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  name        String    @unique
  isActive    Boolean   @default(true) @map("is_active")

  ledgerEntries      WalletLedger[]
  payouts            Payout[]
  vendorPayments     VendorPayment[]
  utangs             Utang[]
  utangPayments      UtangPayment[]
  piutangs           Piutang[]
  piutangCollections PiutangCollection[]
  asetTetap          AsetTetap[]
  modalAwal          ModalAwal?

  @@map("wallets")
}

// ─────────────────────────────────────────────
// 11. Payout
// ─────────────────────────────────────────────
model Payout {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  createdBy         String?   @map("created_by")

  orderNo           String    @unique @map("order_no")
  releasedDate      DateTime  @map("released_date")
  platform          String?   @map("platform")
  omzet             Int
  platformFee       Int       @map("platform_fee")
  amsFee            Int       @map("ams_fee")
  platformFeeOther  Int       @default(0) @map("platform_fee_other")
  bebanOngkir       Int       @default(0) @map("beban_ongkir")
  totalIncome       Int       @map("total_income")
  walletId          String    @map("wallet_id")
  source            String?   @map("source")

  orderId           String?   @unique @map("order_id")
  order             Order?    @relation(fields: [orderId], references: [id])
  wallet            Wallet    @relation(fields: [walletId], references: [id])

  @@index([orderNo])
  @@index([walletId])
  @@index([platform])
  @@index([releasedDate])
  @@map("payouts")
}

// ─────────────────────────────────────────────
// 12. WalletLedger
// ─────────────────────────────────────────────
model WalletLedger {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  createdBy   String?       @map("created_by")

  walletId    String        @map("wallet_id")
  trxDate     DateTime      @map("trx_date")
  trxType     WalletTrxType @map("trx_type")
  category    String?
  amount      Int
  note        String?
  refOrderNo  String?       @map("ref_order_no")

  wallet      Wallet        @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([trxDate])
  @@index([trxType])
  @@map("wallet_ledger")
}

// ─────────────────────────────────────────────
// 13. MasterCategory
// ─────────────────────────────────────────────
model MasterCategory {
  id            String              @id @default(cuid())
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  categoryType  MasterCategoryType  @map("category_type")
  name          String
  isActive      Boolean             @default(true) @map("is_active")

  @@map("master_categories")
}

// ─────────────────────────────────────────────
// 14. MasterReason
// ─────────────────────────────────────────────
model MasterReason {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  reasonCode  String          @map("reason_code")
  name        String
  direction   LedgerDirection
  isActive    Boolean         @default(true) @map("is_active")

  @@map("master_reasons")
}

// ─────────────────────────────────────────────
// 15. Vendor
// ─────────────────────────────────────────────
model Vendor {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  createdBy     String?   @map("created_by")

  vendorCode    String    @unique @map("vendor_code")
  namaVendor    String    @map("nama_vendor")
  kontak        String?
  email         String?
  alamat        String?
  rekening      String?
  bank          String?
  termPayment   Int       @default(0) @map("term_payment")
  isActive      Boolean   @default(true) @map("is_active")

  purchaseOrders  PurchaseOrder[]
  payments        VendorPayment[]

  @@map("vendors")
}

// ─────────────────────────────────────────────
// 16. PurchaseOrder
// ─────────────────────────────────────────────
model PurchaseOrder {
  id                String          @id @default(cuid())
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  createdBy         String?         @map("created_by")

  poNumber          String          @unique @map("po_number")
  vendorId          String          @map("vendor_id")
  vendorName        String          @map("vendor_name")
  poDate            DateTime        @map("po_date")
  expectedDate      DateTime?       @map("expected_date")
  status            POStatus        @default(OPEN)
  paymentStatus     POPaymentStatus @default(UNPAID) @map("payment_status")
  totalItems        Int             @default(0) @map("total_items")
  totalQtyOrder     Int             @default(0) @map("total_qty_order")
  totalQtyReceived  Int             @default(0) @map("total_qty_received")
  totalAmount       Int             @default(0) @map("total_amount")
  totalPaid         Int             @default(0) @map("total_paid")
  note              String?

  vendor            Vendor              @relation(fields: [vendorId], references: [id])
  items             PurchaseOrderItem[]
  goodsReceipts     GoodsReceipt[]
  vendorPayments    VendorPayment[]
  piutangs          Piutang[]

  @@index([vendorId])
  @@index([status])
  @@map("purchase_orders")
}

// ─────────────────────────────────────────────
// 17. PurchaseOrderItem
// ─────────────────────────────────────────────
model PurchaseOrderItem {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  poId          String        @map("po_id")
  poNumber      String        @map("po_number")
  vendorId      String        @map("vendor_id")
  vendorName    String        @map("vendor_name")
  sku           String
  productName   String        @map("product_name")
  qtyOrder      Int           @map("qty_order")
  qtyReceived   Int           @default(0) @map("qty_received")
  unitPrice     Int           @default(0) @map("unit_price")
  status        POItemStatus  @default(OPEN)

  purchaseOrder MasterProduct @relation(fields: [sku], references: [sku])
  po            PurchaseOrder @relation(fields: [poId], references: [id])

  @@index([poId])
  @@index([sku])
  @@map("purchase_order_items")
}

// ─────────────────────────────────────────────
// 18. GoodsReceipt
// ─────────────────────────────────────────────
model GoodsReceipt {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  createdBy     String?   @map("created_by")

  poId          String    @map("po_id")
  poNumber      String    @map("po_number")
  vendorId      String    @map("vendor_id")
  vendorName    String    @map("vendor_name")
  receiptDate   DateTime  @map("receipt_date")
  itemsJson     Json?     @map("items_json")
  note          String?

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])

  @@index([poId])
  @@map("goods_receipts")
}

// ─────────────────────────────────────────────
// 19. VendorPayment
// ─────────────────────────────────────────────
model VendorPayment {
  id              String              @id @default(cuid())
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  createdBy       String?             @map("created_by")

  paymentNumber   String?             @map("payment_number")
  paymentDate     DateTime            @map("payment_date")
  vendorId        String              @map("vendor_id")
  vendorName      String              @map("vendor_name")
  poId            String?             @map("po_id")
  poNumber        String?             @map("po_number")
  walletId        String              @map("wallet_id")
  walletName      String              @map("wallet_name")
  amount          Int
  paymentType     VendorPaymentType   @map("payment_type")
  status          VendorPaymentStatus @default(COMPLETED)
  note            String?

  vendor          Vendor        @relation(fields: [vendorId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [poId], references: [id])
  wallet          Wallet        @relation(fields: [walletId], references: [id])

  @@index([vendorId])
  @@index([poId])
  @@map("vendor_payments")
}

// ─────────────────────────────────────────────
// 20. Utang
// ─────────────────────────────────────────────
model Utang {
  id                String      @id @default(cuid())
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  createdBy         String?     @map("created_by")

  type              UtangType
  creditorName      String      @map("creditor_name")
  sourceWalletId    String      @map("source_wallet_id")
  sourceWalletName  String      @map("source_wallet_name")
  amount            Int
  amountPaid        Int         @default(0) @map("amount_paid")
  trxDate           DateTime    @map("trx_date")
  dueDate           DateTime?   @map("due_date")
  status            UtangStatus @default(OUTSTANDING)
  proofImageUrl     String?     @map("proof_image_url")
  note              String?

  sourceWallet      Wallet      @relation(fields: [sourceWalletId], references: [id])
  payments          UtangPayment[]

  @@map("utangs")
}

// ─────────────────────────────────────────────
// 21. UtangPayment
// ─────────────────────────────────────────────
model UtangPayment {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  utangId       String    @map("utang_id")
  paymentDate   DateTime  @map("payment_date")
  amount        Int
  walletId      String    @map("wallet_id")
  walletName    String    @map("wallet_name")
  proofImageUrl String?   @map("proof_image_url")
  note          String?

  utang         Utang     @relation(fields: [utangId], references: [id])
  wallet        Wallet    @relation(fields: [walletId], references: [id])

  @@index([utangId])
  @@map("utang_payments")
}

// ─────────────────────────────────────────────
// 22. Piutang
// ─────────────────────────────────────────────
model Piutang {
  id                  String            @id @default(cuid())
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  createdBy           String?           @map("created_by")

  type                PiutangType
  debtorName          String            @map("debtor_name")
  sourceWalletId      String            @map("source_wallet_id")
  sourceWalletName    String            @map("source_wallet_name")
  amount              Int
  amountCollected     Int               @default(0) @map("amount_collected")
  trxDate             DateTime          @map("trx_date")
  dueDate             DateTime?         @map("due_date")
  status              PiutangStatus     @default(OUTSTANDING)
  relatedEntityId     String?           @map("related_entity_id")
  relatedEntityType   RelatedEntityType? @map("related_entity_type")
  proofImageUrl       String?           @map("proof_image_url")
  note                String?

  sourceWallet        Wallet            @relation(fields: [sourceWalletId], references: [id])
  purchaseOrder       PurchaseOrder?    @relation(fields: [relatedEntityId], references: [id])
  collections         PiutangCollection[]

  @@map("piutangs")
}

// ─────────────────────────────────────────────
// 23. PiutangCollection
// ─────────────────────────────────────────────
model PiutangCollection {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  piutangId       String    @map("piutang_id")
  collectionDate  DateTime  @map("collection_date")
  amount          Int
  walletId        String    @map("wallet_id")
  walletName      String    @map("wallet_name")
  proofImageUrl   String?   @map("proof_image_url")
  note            String?

  piutang         Piutang   @relation(fields: [piutangId], references: [id])
  wallet          Wallet    @relation(fields: [walletId], references: [id])

  @@index([piutangId])
  @@map("piutang_collections")
}

// ─────────────────────────────────────────────
// 24. AuditLog
// ─────────────────────────────────────────────
model AuditLog {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now()) @map("created_at")

  entityType    String      @map("entity_type")
  action        AuditAction
  entityId      String?     @map("entity_id")
  refOrderNo    String?     @map("ref_order_no")
  beforeJson    Json?       @map("before_json")
  afterJson     Json?       @map("after_json")
  note          String?
  performedBy   String      @map("performed_by")

  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// 25. MasterExpenseCategory
// ─────────────────────────────────────────────
model MasterExpenseCategory {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  name        String   @unique
  group       String
  isActive    Boolean  @default(true) @map("is_active")
  isSystem    Boolean  @default(false) @map("is_system")

  @@index([group])
  @@map("master_expense_categories")
}

// ─────────────────────────────────────────────
// 26. AsetTetap
// ─────────────────────────────────────────────
model AsetTetap {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  createdBy          String?   @map("created_by")

  namaAset           String    @map("nama_aset")
  nilaiPerolehan     Int       @map("nilai_perolehan")
  tanggalBeli        DateTime  @map("tanggal_beli")
  umurEkonomisThn    Int       @map("umur_ekonomis_thn")
  isActive           Boolean   @default(true) @map("is_active")
  walletId           String?   @map("wallet_id")
  note               String?

  wallet             Wallet?   @relation(fields: [walletId], references: [id])

  @@index([isActive])
  @@map("aset_tetap")
}

// ─────────────────────────────────────────────
// 27. ModalAwal
// ─────────────────────────────────────────────
model ModalAwal {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  walletId      String   @unique @map("wallet_id")
  jumlah        Int
  tanggalSetup  DateTime @map("tanggal_setup")
  note          String?

  wallet        Wallet   @relation(fields: [walletId], references: [id])

  @@map("modal_awal")
}

// ─────────────────────────────────────────────
// 28. SuggestRevision
// ─────────────────────────────────────────────
model SuggestRevision {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  title         String
  description   String?
  imagesBase64  String[] @default([]) @map("images_base64")
  status        String   @default("PENDING")
  createdBy     String?  @map("created_by")

  @@map("suggest_revisions")
}

// ─────────────────────────────────────────────
// SKU Mapping (Produk Gabungan)
// Mapping dari SKU marketplace (misal "A + B") ke SKU internal DB
// ─────────────────────────────────────────────
model SkuMapping {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")

  fromSku   String   @unique @map("from_sku")  // SKU dari marketplace (col A)
  toSku     String   @map("to_sku")            // SKU internal DB (col B, bisa ada +)
  isActive  Boolean  @default(true) @map("is_active")

  @@map("sku_mappings")
}

// ─────────────────────────────────────────────
// App Settings
// ─────────────────────────────────────────────
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("app_settings")
}
